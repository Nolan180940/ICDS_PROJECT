```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.py*.py.class

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Logs
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage
.coverage
coverage/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/
.installed.cfg
*.egg

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# OS
.DS_Store
Thumbs.db
```